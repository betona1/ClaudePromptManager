CPM_SECRET_KEY=           # 비워두면 자동생성
CPM_DEBUG=true            # 운영서버는 false
CPM_ALLOWED_HOSTS=*       # 도메인 설정 시: cpm.yourdomain.com,localhost
CPM_WEB_PORT=9200
CPM_SERVER=http://localhost:9200  # 원격 hook용

# 프로젝트 삭제 비밀번호
delpasswd=

# Google OAuth (권장)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=

# GitHub OAuth (선택)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_SECRET=

# GitHub 연동 (선택)
GITHUB_TOKEN=
GITHUB_USERNAME=

# Google Sheets 연동 (선택)
GOOGLE_SHEETS_CREDENTIALS=       # 서비스 계정 JSON 파일 경로
# GOOGLE_SHEETS_CREDENTIALS_JSON=  # 또는 인라인 JSON (Docker용)
